			TextSize = 12,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = card
		})
		local ValLabel = Create("TextLabel", {
			Size = UDim2.new(0, 44, 0, 14),
			Position = UDim2.new(1, -50, 0, 6),
			BackgroundTransparency = 1,
			Text = tostring(value),
			Font = Enum.Font.GothamBold,
			TextSize = 11,
			TextColor3 = T.WhiteFade,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 5,
			Parent = card
		})
		local Track = Create("Frame", {
			Size = UDim2.new(1, -20, 0, 3),
			Position = UDim2.new(0, 10, 0, 32),
			BackgroundColor3 = T.Dark5,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 5,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Track })
		local Fill = Create("Frame", {
			Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 6,
			Parent = Track
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Fill })
		local Knob = Create("Frame", {
			Size = UDim2.new(0, 12, 0, 12),
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 7,
			Parent = Track
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = Knob })
		local draggingSlider = false
		local function updateSlider(input)
			local relX = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
			value = math.floor(min + (max - min) * relX)
			ValLabel.Text = tostring(value)
			Tween(Fill, { Size = UDim2.new(relX, 0, 1, 0) }, 0.04)
			Tween(Knob, { Position = UDim2.new(relX, 0, 0.5, 0) }, 0.04)
			if config.Callback then config.Callback(value) end
		end
		Track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = true
				updateSlider(input)
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				updateSlider(input)
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = false
			end
		end)
		local obj = {}
		function obj:Get() return value end
		function obj:Set(val)
			value = math.clamp(val, min, max)
			local relX = (value - min) / (max - min)
			ValLabel.Text = tostring(value)
			Tween(Fill, { Size = UDim2.new(relX, 0, 1, 0) }, 0.08)
			Tween(Knob, { Position = UDim2.new(relX, 0, 0.5, 0) }, 0.08)
		end
		return obj
	end

