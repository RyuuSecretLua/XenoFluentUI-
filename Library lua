	local function BuildThemeOptions()
		for _, c in pairs(themeDropList:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end
		for _, opt in ipairs(themeOptions) do
			local Item = Create("TextButton", {
				Size = UDim2.new(1, -6, 0, 24),
				Position = UDim2.new(0, 3, 0, 0),
				BackgroundColor3 = opt == selectedTheme and T.Dark5 or T.Dark3,
				BackgroundTransparency = 0,
				Text = opt,
				Font = Enum.Font.Gotham,
				TextSize = 10,
				TextColor3 = opt == selectedTheme and T.White or T.WhiteDim,
				BorderSizePixel = 0,
				ZIndex = 21,
				Parent = themeDropList
			})
			Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Item })
			Create("UIPadding", { PaddingLeft = UDim.new(0, 8), Parent = Item })
			Item.MouseButton1Click:Connect(function()
				selectedTheme = opt
				themeSelLabel.Text = opt
				BuildThemeOptions()
				themeOpen = false
				Tween(themeDropList, { Size = UDim2.new(0, 115, 0, 0) }, 0.15)
				task.delay(0.18, function() themeDropList.Visible = false end)
				themeArrow.Text = "v"
			end)
		end
		themeDropList.Size = UDim2.new(0, 115, 0, themeDLL.AbsoluteContentSize.Y + 6)
	end

	themeDropBtn.MouseButton1Click:Connect(function()
		themeOpen = not themeOpen
		if themeOpen then
			BuildThemeOptions()
			themeDropList.Visible = true
			local h = themeDLL.AbsoluteContentSize.Y + 6
			themeDropList.Size = UDim2.new(0, 115, 0, 0)
			Tween(themeDropList, { Size = UDim2.new(0, 115, 0, h) }, 0.18, Enum.EasingStyle.Quart)
