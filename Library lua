		Create("TextLabel", {
			Size = UDim2.new(1, -140, 1, 0),
			Position = UDim2.new(0, 10, 0, 0),
			BackgroundTransparency = 1,
			Text = config.Title or "SelectToggle",
			Font = Enum.Font.GothamSemibold,
			TextSize = 12,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 11,
			Parent = card
		})
		local DropBtn = Create("TextButton", {
			Size = UDim2.new(0, 115, 0, 24),
			Position = UDim2.new(1, -122, 0.5, -12),
			BackgroundColor3 = T.Dark4,
			BackgroundTransparency = 0,
			Text = "",
			BorderSizePixel = 0,
			ZIndex = 12,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = DropBtn })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropBtn })
		local function GetSummary()
			local sel = {}
			for _, opt in ipairs(options) do
				if states[opt] then table.insert(sel, opt) end
			end
			if #sel == 0 then return "None" end
			if #sel == 1 then return sel[1] end
			return sel[1] .. " +" .. (#sel - 1)
		end
		local SelLabel = Create("TextLabel", {
			Size = UDim2.new(1, -22, 1, 0),
			Position = UDim2.new(0, 8, 0, 0),
			BackgroundTransparency = 1,
			Text = GetSummary(),
			Font = Enum.Font.Gotham,
			TextSize = 10,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 13,
			Parent = DropBtn
		})
		local Arrow = Create("TextLabel", {
			Size = UDim2.new(0, 16, 1, 0),
			Position = UDim2.new(1, -18, 0, 0),
			BackgroundTransparency = 1,
			Text = "v",
			Font = Enum.Font.GothamBold,
			TextSize = 9,
			TextColor3 = T.WhiteFade,
			ZIndex = 13,
			Parent = DropBtn
		})
		local DropList = Create("Frame", {
			Size = UDim2.new(0, 115, 0, 0),
			Position = UDim2.new(1, -122, 1, 3),
			BackgroundColor3 = T.Dark3,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Visible = false,
			ZIndex = 20,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = DropList })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropList })
		Create("UIPadding", { PaddingTop = UDim.new(0, 3), PaddingBottom = UDim.new(0, 3), Parent = DropList })
		local DLL = Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = DropList })
		local itemRefs = {}
		local function BuildOptions()
			for _, c in pairs(DropList:GetChildren()) do
				if c:IsA("Frame") then c:Destroy() end
			end
			itemRefs = {}
			for _, opt in ipairs(options) do
				local row = Create("Frame", {
					Size = UDim2.new(1, -6, 0, 24),
					Position = UDim2.new(0, 3, 0, 0),
					BackgroundColor3 = states[opt] and T.Dark5 or T.Dark3,
					BackgroundTransparency = 0,
					BorderSizePixel = 0,
					ZIndex = 21,
					Parent = DropList
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = row })
				Create("TextLabel", {
					Size = UDim2.new(1, -30, 1, 0),
					Position = UDim2.new(0, 8, 0, 0),
					BackgroundTransparency = 1,
					Text = opt,
					Font = Enum.Font.Gotham,
					TextSize = 10,
					TextColor3 = T.White,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 22,
					Parent = row
				})
				local CheckBox = Create("Frame", {
					Size = UDim2.new(0, 13, 0, 13),
					Position = UDim2.new(1, -18, 0.5, -6),
					BackgroundColor3 = states[opt] and T.Dark5 or T.Dark3,
					BackgroundTransparency = 0,
					BorderSizePixel = 0,
					ZIndex = 22,
					Parent = row
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = CheckBox })
				local CStroke = Create("UIStroke", { Color = states[opt] and T.White or T.Border, Transparency = 0, Thickness = 1, Parent = CheckBox })
				local CheckMark = Create("TextLabel", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "v",
					Font = Enum.Font.GothamBold,
					TextSize = 8,
					TextColor3 = T.White,
					TextTransparency = states[opt] and 0 or 1,
					ZIndex = 23,
					Parent = CheckBox
				})
				itemRefs[opt] = { row = row, box = CheckBox, mark = CheckMark, stroke = CStroke }
				local Clicker = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 24, Parent = row })
				Clicker.MouseEnter:Connect(function()
					if not states[opt] then Tween(row, { BackgroundColor3 = T.Dark4 }, 0.1) end
				end)
				Clicker.MouseLeave:Connect(function()
					if not states[opt] then Tween(row, { BackgroundColor3 = T.Dark3 }, 0.1) end
				end)
				Clicker.MouseButton1Click:Connect(function()
					states[opt] = not states[opt]
					local ref = itemRefs[opt]
					if states[opt] then
						Tween(ref.row, { BackgroundColor3 = T.Dark5 }, 0.15)
						Tween(ref.box, { BackgroundColor3 = T.Dark5 }, 0.15)
						Tween(ref.mark, { TextTransparency = 0 }, 0.12)
						ref.stroke.Color = T.White
					else
						Tween(ref.row, { BackgroundColor3 = T.Dark3 }, 0.15)
						Tween(ref.box, { BackgroundColor3 = T.Dark3 }, 0.15)
						Tween(ref.mark, { TextTransparency = 1 }, 0.12)
						ref.stroke.Color = T.Border
					end
					SelLabel.Text = GetSummary()
					local sel = {}
					for k, v in pairs(states) do if v then table.insert(sel, k) end end
					if config.Callback then config.Callback(states, sel) end
				end)
			end
			DropList.Size = UDim2.new(0, 115, 0, DLL.AbsoluteContentSize.Y + 6)
		end
		DropBtn.MouseButton1Click:Connect(function()
			open = not open
			if open then
				BuildOptions()
				DropList.Visible = true
				local h = DLL.AbsoluteContentSize.Y + 6
				DropList.Size = UDim2.new(0, 115, 0, 0)
				Tween(DropList, { Size = UDim2.new(0, 115, 0, h) }, 0.18, Enum.EasingStyle.Quart)
				Arrow.Text = "^"
			else
				Tween(DropList, { Size = UDim2.new(0, 115, 0, 0) }, 0.15)
				task.delay(0.18, function() DropList.Visible = false end)
				Arrow.Text = "v"
			end
		end)
		local obj = {}
		function obj:GetSelected()
			local sel = {}
			for k, v in pairs(states) do if v then table.insert(sel, k) end end
			return sel
		end
		function obj:GetStates() return states end
		return obj
	end

	return Tab
end

return XenoFluentUI
