			Text = config.Title or "Button",
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = card
		})

		local ripple = Create("Frame", {
			Size = UDim2.new(0, 0, 0, 0),
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.5, 0, 0.5, 0),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0.85,
			BorderSizePixel = 0,
			ZIndex = 6,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = ripple })

		local CR = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 7, Parent = card })
		CR.MouseEnter:Connect(function() Tween(card, { BackgroundTransparency = 0.15 }, 0.12) end)
		CR.MouseLeave:Connect(function() Tween(card, { BackgroundTransparency = 0.3 }, 0.12) end)
		CR.MouseButton1Click:Connect(function()
			ripple.Size = UDim2.new(0, 0, 0, 0)
			ripple.BackgroundTransparency = 0.85
			Tween(ripple, { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1 }, 0.35)
			if config.Callback then config.Callback() end
		end)

		return CR
	end

	function Tab:Toggle(config)
		config = config or {}
		local state = config.Default or false
		local card = MakeCard(42)
		card.LayoutOrder = config.LayoutOrder or 0

		Create("TextLabel", {
			Size = UDim2.new(1, -68, 1, 0),
			Position = UDim2.new(0, 12, 0, 0),
			BackgroundTransparency = 1,
			Text = config.Title or "Toggle",
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = card
		})

		local Track = Create("Frame", {
			Size = UDim2.new(0, 38, 0, 20),
			Position = UDim2.new(1, -49, 0.5, -10),
			BackgroundColor3 = state and T.Dark5 or T.Dark3,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 6,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 10), Parent = Track })
		local TStroke = Create("UIStroke", { Color = state and T.White or T.Border, Transparency = 0, Thickness = 1, Parent = Track })

		local Knob = Create("Frame", {
			Size = UDim2.new(0, 14, 0, 14),
			Position = state and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 7,
			Parent = Track
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = Knob })

		local CR = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 8, Parent = card })
		CR.MouseButton1Click:Connect(function()
			state = not state
			if state then
				Tween(Track, { BackgroundColor3 = T.Dark5 }, 0.18)
				Tween(Knob, { Position = UDim2.new(1, -17, 0.5, -7) }, 0.18)
				TStroke.Color = T.White
			else
				Tween(Track, { BackgroundColor3 = T.Dark3 }, 0.18)
				Tween(Knob, { Position = UDim2.new(0, 3, 0.5, -7) }, 0.18)
				TStroke.Color = T.Border
			end
			if config.Callback then config.Callback(state) end
		end)
		CR.MouseEnter:Connect(function() Tween(card, { BackgroundTransparency = 0.15 }, 0.12) end)
		CR.MouseLeave:Connect(function() Tween(card, { BackgroundTransparency = 0.3 }, 0.12) end)

		local obj = {}
		function obj:Set(val)
			state = val
			if state then
				Tween(Track, { BackgroundColor3 = T.Dark5 }, 0.18)
				Tween(Knob, { Position = UDim2.new(1, -17, 0.5, -7) }, 0.18)
				TStroke.Color = T.White
			else
				Tween(Track, { BackgroundColor3 = T.Dark3 }, 0.18)
				Tween(Knob, { Position = UDim2.new(0, 3, 0.5, -7) }, 0.18)
				TStroke.Color = T.Border
			end
		end
		function obj:Get() return state end
		return obj
	end

