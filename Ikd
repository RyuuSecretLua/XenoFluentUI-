function XenoFluentUI:Tab(config)
	config = config or {}
	local tab = {}
	tab.Title = config.Title or "Tab"
	local isActive = #self.Tabs == 0

	local TabBtn = Create("TextButton", {
		Name = "Tab_" .. tab.Title,
		Size = UDim2.new(1, 0, 0, 32),
		BackgroundColor3 = T.Dark3,
		BackgroundTransparency = isActive and 0.3 or 1,
		Text = "",
		BorderSizePixel = 0,
		ZIndex = 4,
		Parent = self.TabList
	})
	Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = TabBtn })

	local TabLabel = Create("TextLabel", {
		Size = UDim2.new(1, -12, 1, 0),
		Position = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Text = tab.Title,
		Font = Enum.Font.GothamSemibold,
		TextSize = 12,
		TextColor3 = isActive and T.White or T.WhiteFade,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 5,
		Parent = TabBtn
	})
	tab.Label = TabLabel
	tab.TabBtn = TabBtn

	local Page = Create("ScrollingFrame", {
		Name = "Page_" .. tab.Title,
		Size = UDim2.new(1, 0, 1, -50),
		Position = UDim2.new(0, 0, 0, 50),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = T.Border,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		Visible = isActive,
		ZIndex = 3,
		Parent = self.ContentArea
	})
	Create("UIPadding", { PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12), PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 12), Parent = Page })
	local LL = Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), Parent = Page })
	LL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		Page.CanvasSize = UDim2.new(0, 0, 0, LL.AbsoluteContentSize.Y + 20)
	end)
	tab.Page = Page

	if isActive then self.ActiveTab = tab end

	TabBtn.MouseButton1Click:Connect(function()
		if self.ActiveTab == tab then return end
		if self.ActiveTab then
			local old = self.ActiveTab
			old.Page.Visible = false
			Tween(old.TabBtn, { BackgroundTransparency = 1 }, 0.15)
			Tween(old.Label, { TextColor3 = T.WhiteFade }, 0.15)
		end
		tab.Page.Visible = true
		Tween(TabBtn, { BackgroundColor3 = T.Dark3, BackgroundTransparency = 0.3 }, 0.15)
		Tween(TabLabel, { TextColor3 = T.White }, 0.15)
		self.ActiveTab = tab
	end)
	TabBtn.MouseEnter:Connect(function()
		if self.ActiveTab ~= tab then Tween(TabBtn, { BackgroundColor3 = T.Dark3, BackgroundTransparency = 0.6 }, 0.12) end
	end)
	TabBtn.MouseLeave:Connect(function()
		if self.ActiveTab ~= tab then Tween(TabBtn, { BackgroundTransparency = 1 }, 0.12) end
	end)

	self.TabList.CanvasSize = UDim2.new(0, 0, 0, self.TabLL.AbsoluteContentSize.Y + 8)
	table.insert(self.Tabs, tab)

	local Tab = {}

	local function MakeCard(h)
		local card = Create("Frame", {
			Size = UDim2.new(1, 0, 0, h or 42),
			BackgroundColor3 = T.Dark3,
			BackgroundTransparency = 0.3,
			BorderSizePixel = 0,
			ZIndex = 4,
			Parent = Page
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = card })
		return card
	end

	function Tab:Section(config)
		config = config or {}
