	function Tab:Slider(config)
		config = config or {}
		local min = config.Min or 0
		local max = config.Max or 100
		local value = math.clamp(config.Default or min, min, max)

		local card = MakeCard(56)
		card.LayoutOrder = config.LayoutOrder or 0

		Create("TextLabel", {
			Size = UDim2.new(1, -60, 0, 16),
			Position = UDim2.new(0, 12, 0, 8),
			BackgroundTransparency = 1,
			Text = config.Title or "Slider",
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 5,
			Parent = card
		})

		local ValLabel = Create("TextLabel", {
			Size = UDim2.new(0, 50, 0, 16),
			Position = UDim2.new(1, -58, 0, 8),
			BackgroundTransparency = 1,
			Text = tostring(value),
			Font = Enum.Font.GothamBold,
			TextSize = 12,
			TextColor3 = T.WhiteFade,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 5,
			Parent = card
		})

		local Track = Create("Frame", {
			Size = UDim2.new(1, -24, 0, 4),
			Position = UDim2.new(0, 12, 0, 36),
			BackgroundColor3 = T.Dark5,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 5,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Track })

		local Fill = Create("Frame", {
			Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 6,
			Parent = Track
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = Fill })

		local Knob = Create("Frame", {
			Size = UDim2.new(0, 14, 0, 14),
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
			BackgroundColor3 = T.White,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ZIndex = 7,
			Parent = Track
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = Knob })

		local draggingSlider = false

		local function updateSlider(input)
			local relX = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
			value = math.floor(min + (max - min) * relX)
			ValLabel.Text = tostring(value)
			Tween(Fill, { Size = UDim2.new(relX, 0, 1, 0) }, 0.05)
			Tween(Knob, { Position = UDim2.new(relX, 0, 0.5, 0) }, 0.05)
			if config.Callback then config.Callback(value) end
		end

		Track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = true
				updateSlider(input)
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				updateSlider(input)
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingSlider = false
			end
		end)

		local obj = {}
		function obj:Get() return value end
		function obj:Set(val)
			value = math.clamp(val, min, max)
			local relX = (value - min) / (max - min)
			ValLabel.Text = tostring(value)
			Tween(Fill, { Size = UDim2.new(relX, 0, 1, 0) }, 0.1)
			Tween(Knob, { Position = UDim2.new(relX, 0, 0.5, 0) }, 0.1)
		end
		return obj
	end

	function Tab:Select(config)
		config = config or {}
		local options = config.Options or {}
		local selected = config.Default or (options[1] or "")
		local open = false

		local card = MakeCard(42)
		card.LayoutOrder = config.LayoutOrder or 0
		card.ClipsDescendants = false
		card.ZIndex = 10

		Create("TextLabel", {
			Size = UDim2.new(0.5, 0, 1, 0),
			Position = UDim2.new(0, 12, 0, 0),
			BackgroundTransparency = 1,
			Text = config.Title or "Select",
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 11,
			Parent = card
		})

		local DropBtn = Create("TextButton", {
			Size = UDim2.new(0, 120, 0, 27),
			Position = UDim2.new(1, -130, 0.5, -13),
			BackgroundColor3 = T.Dark4,
			BackgroundTransparency = 0,
			Text = "",
			BorderSizePixel = 0,
			ZIndex = 12,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = DropBtn })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropBtn })

		local SelLabel = Create("TextLabel", {
			Size = UDim2.new(1, -24, 1, 0),
			Position = UDim2.new(0, 9, 0, 0),
			BackgroundTransparency = 1,
			Text = selected,
			Font = Enum.Font.Gotham,
			TextSize = 11,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 13,
			Parent = DropBtn
		})

		local Arrow = Create("TextLabel", {
			Size = UDim2.new(0, 18, 1, 0),
			Position = UDim2.new(1, -20, 0, 0),
			BackgroundTransparency = 1,
			Text = "▾",
			Font = Enum.Font.GothamBold,
			TextSize = 10,
			TextColor3 = T.WhiteFade,
			ZIndex = 13,
			Parent = DropBtn
		})

		local DropList = Create("Frame", {
			Size = UDim2.new(0, 120, 0, 0),
			Position = UDim2.new(1, -130, 1, 4),
			BackgroundColor3 = T.Dark3,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Visible = false,
			ZIndex = 20,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = DropList })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropList })
		Create("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), Parent = DropList })
		local DLL = Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = DropList })

		local function BuildOptions()
			for _, c in pairs(DropList:GetChildren()) do
				if c:IsA("TextButton") then c:Destroy() end
			end
			for _, opt in ipairs(options) do
				local Item = Create("TextButton", {
					Size = UDim2.new(1, -8, 0, 27),
					Position = UDim2.new(0, 4, 0, 0),
					BackgroundColor3 = opt == selected and T.Dark5 or T.Dark3,
					BackgroundTransparency = 0,
					Text = opt,
					Font = Enum.Font.Gotham,
					TextSize = 11,
					TextColor3 = opt == selected and T.White or T.WhiteDim,
					BorderSizePixel = 0,
					ZIndex = 21,
					Parent = DropList
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = Item })
				Create("UIPadding", { PaddingLeft = UDim.new(0, 9), Parent = Item })
				Item.MouseEnter:Connect(function()
					if opt ~= selected then Tween(Item, { BackgroundColor3 = T.Dark4 }, 0.1) end
				end)
				Item.MouseLeave:Connect(function()
					if opt ~= selected then Tween(Item, { BackgroundColor3 = T.Dark3 }, 0.1) end
				end)
				Item.MouseButton1Click:Connect(function()
					selected = opt
					SelLabel.Text = selected
					BuildOptions()
					open = false
					Tween(DropList, { Size = UDim2.new(0, 120, 0, 0) }, 0.18)
					task.delay(0.2, function() DropList.Visible = false end)
					Arrow.Text = "▾"
					if config.Callback then config.Callback(selected) end
				end)
			end
			DropList.Size = UDim2.new(0, 120, 0, DLL.AbsoluteContentSize.Y + 8)
		end

		DropBtn.MouseButton1Click:Connect(function()
			open = not open
			if open then
				BuildOptions()
				DropList.Visible = true
				local h = DLL.AbsoluteContentSize.Y + 8
				DropList.Size = UDim2.new(0, 120, 0, 0)
				Tween(DropList, { Size = UDim2.new(0, 120, 0, h) }, 0.2, Enum.EasingStyle.Quart)
				Arrow.Text = "▴"
			else
				Tween(DropList, { Size = UDim2.new(0, 120, 0, 0) }, 0.18)
				task.delay(0.2, function() DropList.Visible = false end)
				Arrow.Text = "▾"
			end
		end)

		local obj = {}
		function obj:Get() return selected end
		function obj:Set(val) selected = val SelLabel.Text = val end
		function obj:AddOption(opt) table.insert(options, opt) end
		return obj
	end

	function Tab:SelectToggle(config)
		config = config or {}
		local options = config.Options or {}
		local states = {}
		for _, opt in ipairs(options) do states[opt] = false end
		if config.Default then
			for _, d in ipairs(config.Default) do states[d] = true end
		end

		local open = false
		local card = MakeCard(42)
		card.LayoutOrder = config.LayoutOrder or 0
		card.ClipsDescendants = false
		card.ZIndex = 10

		Create("TextLabel", {
			Size = UDim2.new(0.5, 0, 1, 0),
			Position = UDim2.new(0, 12, 0, 0),
			BackgroundTransparency = 1,
			Text = config.Title or "SelectToggle",
			Font = Enum.Font.GothamSemibold,
			TextSize = 13,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 11,
			Parent = card
		})

		local DropBtn = Create("TextButton", {
			Size = UDim2.new(0, 120, 0, 27),
			Position = UDim2.new(1, -130, 0.5, -13),
			BackgroundColor3 = T.Dark4,
			BackgroundTransparency = 0,
			Text = "",
			BorderSizePixel = 0,
			ZIndex = 12,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = DropBtn })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropBtn })

		local function GetSummary()
			local sel = {}
			for _, opt in ipairs(options) do
				if states[opt] then table.insert(sel, opt) end
			end
			if #sel == 0 then return "None" end
			if #sel == 1 then return sel[1] end
			return sel[1] .. " +" .. (#sel - 1)
		end

		local SelLabel = Create("TextLabel", {
			Size = UDim2.new(1, -24, 1, 0),
			Position = UDim2.new(0, 9, 0, 0),
			BackgroundTransparency = 1,
			Text = GetSummary(),
			Font = Enum.Font.Gotham,
			TextSize = 11,
			TextColor3 = T.White,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 13,
			Parent = DropBtn
		})

		local Arrow = Create("TextLabel", {
			Size = UDim2.new(0, 18, 1, 0),
			Position = UDim2.new(1, -20, 0, 0),
			BackgroundTransparency = 1,
			Text = "▾",
			Font = Enum.Font.GothamBold,
			TextSize = 10,
			TextColor3 = T.WhiteFade,
			ZIndex = 13,
			Parent = DropBtn
		})

		local DropList = Create("Frame", {
			Size = UDim2.new(0, 120, 0, 0),
			Position = UDim2.new(1, -130, 1, 4),
			BackgroundColor3 = T.Dark3,
			BackgroundTransparency = 0,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			Visible = false,
			ZIndex = 20,
			Parent = card
		})
		Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = DropList })
		Create("UIStroke", { Color = T.Border, Transparency = 0, Thickness = 1, Parent = DropList })
		Create("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), Parent = DropList })
		local DLL = Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = DropList })

		local itemRefs = {}

		local function BuildOptions()
			for _, c in pairs(DropList:GetChildren()) do
				if c:IsA("Frame") then c:Destroy() end
			end
			itemRefs = {}
			for _, opt in ipairs(options) do
				local row = Create("Frame", {
					Size = UDim2.new(1, -8, 0, 27),
					Position = UDim2.new(0, 4, 0, 0),
					BackgroundColor3 = states[opt] and T.Dark5 or T.Dark3,
					BackgroundTransparency = 0,
					BorderSizePixel = 0,
					ZIndex = 21,
					Parent = DropList
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = row })
				Create("TextLabel", {
					Size = UDim2.new(1, -36, 1, 0),
					Position = UDim2.new(0, 9, 0, 0),
					BackgroundTransparency = 1,
					Text = opt,
					Font = Enum.Font.Gotham,
					TextSize = 11,
					TextColor3 = T.White,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 22,
					Parent = row
				})

				local CheckBox = Create("Frame", {
					Size = UDim2.new(0, 15, 0, 15),
					Position = UDim2.new(1, -22, 0.5, -7),
					BackgroundColor3 = states[opt] and T.Dark5 or T.Dark3,
					BackgroundTransparency = 0,
					BorderSizePixel = 0,
					ZIndex = 22,
					Parent = row
				})
				Create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = CheckBox })
				local CStroke = Create("UIStroke", { Color = states[opt] and T.White or T.Border, Transparency = 0, Thickness = 1, Parent = CheckBox })
				local CheckMark = Create("TextLabel", {
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "✓",
					Font = Enum.Font.GothamBold,
					TextSize = 10,
					TextColor3 = T.White,
					TextTransparency = states[opt] and 0 or 1,
					ZIndex = 23,
					Parent = CheckBox
				})

				itemRefs[opt] = { row = row, box = CheckBox, mark = CheckMark, stroke = CStroke }

				local Clicker = Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 24, Parent = row })
				Clicker.MouseEnter:Connect(function()
					if not states[opt] then Tween(row, { BackgroundColor3 = T.Dark4 }, 0.1) end
				end)
				Clicker.MouseLeave:Connect(function()
					if not states[opt] then Tween(row, { BackgroundColor3 = T.Dark3 }, 0.1) end
				end)
				Clicker.MouseButton1Click:Connect(function()
					states[opt] = not states[opt]
					local ref = itemRefs[opt]
					if states[opt] then
						Tween(ref.row, { BackgroundColor3 = T.Dark5 }, 0.15)
						Tween(ref.box, { BackgroundColor3 = T.Dark5 }, 0.15)
						Tween(ref.mark, { TextTransparency = 0 }, 0.12)
						ref.stroke.Color = T.White
					else
						Tween(ref.row, { BackgroundColor3 = T.Dark3 }, 0.15)
						Tween(ref.box, { BackgroundColor3 = T.Dark3 }, 0.15)
						Tween(ref.mark, { TextTransparency = 1 }, 0.12)
						ref.stroke.Color = T.Border
					end
					SelLabel.Text = GetSummary()
					local sel = {}
					for k, v in pairs(states) do if v then table.insert(sel, k) end end
					if config.Callback then config.Callback(states, sel) end
				end)
			end
			DropList.Size = UDim2.new(0, 120, 0, DLL.AbsoluteContentSize.Y + 8)
		end

		DropBtn.MouseButton1Click:Connect(function()
			open = not open
			if open then
				BuildOptions()
				DropList.Visible = true
				local h = DLL.AbsoluteContentSize.Y + 8
				DropList.Size = UDim2.new(0, 120, 0, 0)
				Tween(DropList, { Size = UDim2.new(0, 120, 0, h) }, 0.2, Enum.EasingStyle.Quart)
				Arrow.Text = "▴"
			else
				Tween(DropList, { Size = UDim2.new(0, 120, 0, 0) }, 0.18)
				task.delay(0.2, function() DropList.Visible = false end)
				Arrow.Text = "▾"
			end
		end)

		local obj = {}
		function obj:GetSelected()
			local sel = {}
			for k, v in pairs(states) do if v then table.insert(sel, k) end end
			return sel
		end
		function obj:GetStates() return states end
		return obj
	end

	return Tab
end

return XenoFluentUI
